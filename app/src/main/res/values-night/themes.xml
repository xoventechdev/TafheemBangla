<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.KitabTafheem" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Tertiary brand color. -->
        <item name="colorTertiary">@color/colorTertiary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <item name="android:windowBackground">@color/cold_gray</item>
        <item name="android:colorBackground">@color/cold_gray</item>
        <item name="colorSurface">@color/mine_shaft_light</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>

        <item name="textColorPrimary">@color/white</item>
        <item name="textColorSecondary">@color/silver</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/silver</item>
        <item name="dividerColor">#333333</item>
    </style>

    <style name="Theme.KitabTafheemNo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <item name="android:windowBackground">@color/cold_gray</item>
        <item name="android:colorBackground">@color/cold_gray</item>
        <item name="colorSurface">@color/mine_shaft_light</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>

        <item name="textColorPrimary">@color/white</item>
        <item name="textColorSecondary">@color/silver</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/silver</item>
        <item name="dividerColor">#333333</item>
    </style>

    <style name="roundedImageViewRounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="PreferenceTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
        <item name="android:background">@color/cold_gray</item>
        <item name="android:windowBackground">@color/cold_gray</item>
        <item name="dividerColor">#333333</item>
    </style>

    <style name="Base.Theme.KitabTafheem" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/cold_gray</item>
        <item name="android:colorBackground">@color/cold_gray</item>
        <item name="colorSurface">@color/mine_shaft_light</item>
        <item name="dividerColor">#333333</item>
    </style>
</resources>