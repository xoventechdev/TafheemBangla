    <!-- Default blue white theme -->
    <style name="BlueWhiteTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryDark">@color/dodger_blue</item>
        <item name="colorAccent">@color/dodger_blue</item>

        <item name="textColorPrimary">@color/mine_shaft</item>
        <item name="textColorSecondary">@color/gray</item>

        <item name="android:textColorPrimary">@color/mine_shaft</item>
        <item name="android:textColorSecondary">@color/gray</item>
        <item name="android:textColorTertiary">@color/gray</item>
        <item name="android:textColorHint">@color/gray</item>
        <item name="android:editTextColor">@color/gray</item>

        <!-- Background colors -->
        <item name="mainBackgroundStartColor">@color/white</item>
        <item name="mainBackgroundEndColor">@color/alabaster</item>
        <item name="navigationBackgroundStartColor">@color/alabaster</item>
        <item name="navigationBackgroundEndColor">@color/wild_sand</item>
        <item name="navigationCheckedColor">@color/dodger_blue</item>
        <item name="navigationUnCheckedColor">@color/boulder</item>

        <!-- Progressbar colors -->
        <item name="progressbarBackgroundColor">@color/wild_sand</item>
        <item name="progressbarColor">@color/dodger_blue</item>
        <item name="progressbarMainTextColor">@color/curious_blue</item>

        <!-- Notification icons colors -->
        <item name="notificationEnabledIconColor">@color/jade</item>
        <item name="notificationDisabledIconColor">@color/amaranth</item>

        <!-- Tooltip appearance -->
        <item name="tooltipBackgroundColor">@color/dodger_blue</item>
        <item name="tooltipTextColor">@color/alabaster</item>

        <!-- toolbar appearance -->
        <item name="toolbarBackgroundColor">@color/dodger_blue</item>
        <item name="toolbarTextColorPrimary">@color/alabaster</item>
        <item name="toolbarTextColorSecondary">@color/iron</item>
        <item name="toolbarTabBackground">@drawable/tab_color_selector</item>

        <item name="alertDialogTheme">@style/AlertDialogTheme</item>
        <item name="android:textViewStyle">@style/RobotoTextViewStyle</item>
        <item name="buttonStyle">@style/RobotoButtonStyle</item>

        <!-- Main icons colors -->
        <item name="iconsMainColor">@color/dodger_blue</item>

        <!-- Checkbox colors -->
        <item name="colorControlActivated">@color/spray</item>
        <item name="colorControlNormal">@color/gray</item>

        <!-- Clock colors -->
        <item name="faceTint">@color/dodger_blue</item>
        <item name="hourTint">@color/curious_blue</item>
        <item name="minuteTint">@color/curious_blue</item>
        <item name="secondTint">@color/curious_blue</item>
    </style>


