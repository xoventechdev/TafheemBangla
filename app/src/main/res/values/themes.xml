<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.KitabTafheem" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Tertiary brand color. -->
        <item name="colorTertiary">@color/colorTertiary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <!-- Surface and Background -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:colorBackground">@color/white</item>

        <!-- Text colors -->
        <item name="textColorPrimary">@color/mine_shaft</item>
        <item name="textColorSecondary">@color/boulder</item>
        <item name="android:textColorPrimary">@color/mine_shaft</item>
        <item name="android:textColorSecondary">@color/boulder</item>
        <item name="dividerColor">#EEEEEE</item>
    </style>

    <style name="Theme.KitabTafheemNo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/white</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:colorBackground">@color/white</item>

        <item name="textColorPrimary">@color/mine_shaft</item>
        <item name="textColorSecondary">@color/boulder</item>
        <item name="android:textColorPrimary">@color/mine_shaft</item>
        <item name="android:textColorSecondary">@color/boulder</item>
        <item name="dividerColor">#EEEEEE</item>
    </style>

    <style name="AppTheme" parent="Theme.KitabTafheemNo" />

    <!-- Base style for Light Themes - inherit from Light parent to stay light -->
    <style name="Base.AppTheme.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="textColorPrimary">@color/black</item>
        <item name="textColorSecondary">@color/mine_shaft</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/mine_shaft</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="dividerColor">#EEEEEE</item>
    </style>

    <style name="AppTheme_red" parent="Base.AppTheme.Light">
        <item name="colorPrimary">@color/red_colorPrimary</item>
        <item name="colorPrimaryDark">@color/red_colorPrimaryDark</item>
