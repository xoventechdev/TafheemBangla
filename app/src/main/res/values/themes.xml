    <!-- Tab layout appearance -->
    <style name="FivePrayerTabLayout" parent="Widget.Design.TabLayout">
        <item name="tabGravity">fill</item>
        <item name="tabMaxWidth">0dp</item>
        <item name="tabBackground">?attr/toolbarTabBackground</item>
        <item name="tabSelectedTextColor">?attr/toolbarTextColorPrimary</item>
        <item name="tabTextColor">?attr/toolbarTextColorSecondary</item>
    </style>

    <style name="Theme.AppCompat.DayNight.NoActionBar.FullScreen" parent="@style/Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="RobotoTextViewStyle" parent="android:Widget.TextView">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="RobotoButtonStyle" parent="android:Widget.Holo.Button">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="AlertDialogTheme" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="android:windowTitleStyle">@style/WindowTitleStyle</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">?attr/textColorSecondary</item>
        <item name="textColorAlertDialogListItem">?attr/textColorPrimary</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:colorBackground">?attr/navigationBackgroundStartColor</item>

        <item name="android:editTextPreferenceStyle">@style/myStyle</item>

    </style>

    <style name="myStyle" parent="Preference.DialogPreference.EditTextPreference">
        <item name="colorPrimary">?attr/textColorSecondary</item>
        <item name="colorPrimaryDark">?attr/textColorSecondary</item>
        <item name="textFillColor">?attr/textColorSecondary</item>
        <item name="android:editTextColor">?attr/textColorSecondary</item>
        <item name="android:textColorHint">?attr/textColorSecondary</item>
        <item name="android:textColor">?attr/colorAccent</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">?attr/colorAccent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">?attr/colorAccent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NeutralButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">?attr/colorAccent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WindowTitleStyle" parent="TextAppearance.AppCompat.Title">
        <item name="android:textColor">?attr/textColorPrimary</item>
    </style>









































