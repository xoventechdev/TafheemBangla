<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kalpurush"
            android:gravity="center"
            android:text="@string/download_audio_title"
            android:textColor="?attr/textColorPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/kalpurush"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:text="@string/download_audio_desc"
            android:textColor="?attr/textColorSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Reciter 1: Primary Color (Highlighted) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/bt_sds"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/kalpurush"
                android:text="@string/abdur_rahman_sudais"
                android:textAllCaps="false"
                android:textColor="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_baseline_cloud_download_24"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorOnPrimary" />

            <!-- Reciter 2: Outlined for cleaner look -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/bt_basit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/kalpurush"
                android:text="@string/abdul_basit"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimary"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_baseline_cloud_download_24"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorPrimary"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1dp" />

            <!-- Reciter 3 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/bt_mishary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/kalpurush"
                android:text="@string/mishary_afasy"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimary"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_baseline_cloud_download_24"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorPrimary"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1dp" />

            <!-- Reciter 4 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/bt_misharyBn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/kalpurush"
                android:text="@string/mishary_afasy_bn"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimary"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_baseline_cloud_download_24"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorPrimary"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/popEnd"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kalpurush"
            android:text="@string/cancel"
            android:textColor="?attr/textColorSecondary" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
