<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/Widget.MaterialComponents.Toolbar.Primary">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:navigationIconTint="?attr/colorOnPrimary"
                app:titleTextColor="?attr/colorOnPrimary"
                tools:title="দারসুল কুরআন" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/kalpurush"
                            android:gravity="center"
                            android:textColor="?attr/textColorPrimary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textIsSelectable="true"
                            tools:text="দারসুল কুরআন শিরোনাম" />

                        <TextView
                            android:id="@+id/author"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/kalpurush"
                            android:gravity="center"
                            android:textColor="?attr/textColorSecondary"
                            android:textSize="18sp"
                            android:textIsSelectable="true"
                            tools:text="লেখক" />

                        <View
                            android:layout_width="60dp"
                            android:layout_height="1dp"
                            android:layout_gravity="center"
                            android:layout_marginVertical="16dp"
                            android:background="?attr/textColorSecondary" />

                        <TextView
                            android:id="@+id/content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/kalpurush"
                            android:lineSpacingExtra="8dp"
                            android:textColor="?attr/textColorPrimary"
                            android:textSize="20sp"
                            android:textIsSelectable="true"
                            tools:text="দারসের বিষয়বস্তু এখানে থাকবে..." />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Spacing at the bottom to avoid FAB overlap -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/copy_dars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:contentDescription="Copy Dars"
            android:src="@drawable/ic_baseline_content_copy_24"
            app:backgroundTint="?attr/colorPrimary"
            app:fabSize="normal"
            app:tint="?attr/colorOnPrimary" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>
