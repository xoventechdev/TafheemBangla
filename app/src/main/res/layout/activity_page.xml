<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="?android:attr/colorBackground"
        tools:context=".Activity.PageActivity">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbarlayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimary"
            app:liftOnScroll="true"
            app:elevation="4dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_scrollFlags="scroll|enterAlways|snap"
                app:titleTextColor="?attr/colorOnPrimary"
                app:subtitleTextColor="#D9FFFFFF"
                app:navigationIconTint="?attr/colorOnPrimary"
                style="@style/Widget.MaterialComponents.Toolbar.Primary" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/toolbarLayout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/colorPrimary"
                app:layout_scrollFlags="scroll|enterAlways|snap"
                app:tabMode="scrollable"
                app:tabGravity="fill"
                app:tabIndicatorColor="?attr/colorAccent"
                app:tabIndicatorHeight="3dp"
                app:tabIndicatorFullWidth="false"
                app:tabSelectedTextColor="?attr/colorOnPrimary"
                app:tabTextColor="#B3FFFFFF"
                app:tabRippleColor="#26FFFFFF"
                android:layoutDirection="rtl"
                app:tabPaddingStart="16dp"
                app:tabPaddingEnd="16dp"
                app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle2" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewpager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layoutDirection="rtl"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        <!-- Subtle divider between header and content -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_anchor="@id/appbarlayout"
            app:layout_anchorGravity="bottom"
            app:dividerColor="#1FFFFFFF" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
