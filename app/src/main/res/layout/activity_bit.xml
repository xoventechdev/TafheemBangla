<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".Activity.BitActivity">

        <LinearLayout
            android:layout_margin="5dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <RelativeLayout
                android:padding="2dp"
                android:id="@+id/saveLayout"
                android:gravity="center"
                android:background="@color/white"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="500dp">
                <LinearLayout
                    android:id="@+id/colorOut"
                    android:gravity="center"
                    android:background="@color/common"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:layout_marginHorizontal="5dp"
                        android:gravity="center"
                        android:id="@+id/mainTxt"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="450dp">
                        <TextView
                            android:gravity="center"
                            android:id="@+id/arabic"
                            android:text="صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوَّآلِّينَ ٧"
                            android:textColor="@color/white"
                            android:fontFamily="@font/noorehuda"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp" />
                        <TextView
                            android:gravity="center"
                            android:id="@+id/bangla"
                            android:text=" the Patot thosay. the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay.the Patot thosay. v the Patot thosay.the Patot thosay."
                            android:layout_marginBottom="10dp"
                            android:textColor="@color/white"
                            android:fontFamily="@font/kalpurush"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:textStyle="italic"
                            android:text="jkshskfhs"
                            android:gravity="center"
                            android:id="@+id/ref"
                            android:textColor="@color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_below="@+id/mainTxt"
                        android:layout_marginHorizontal="10dp"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="35dp">
                        <ImageView
                            android:layout_gravity="start"
                            android:src="@drawable/play_tafheem"
                            android:layout_width="0dp"
                            android:layout_weight="2"
                            android:layout_height="35dp"/>
                        <ImageView
                            android:layout_weight="2"
                            android:layout_gravity="end"
                            android:src="@drawable/play_store"
                            android:layout_width="0dp"
                            android:layout_height="38dp"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
        <LinearLayout
            android:background="@color/common"
            android:padding="10dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_gravity="bottom|center_horizontal"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView

                android:layout_marginHorizontal="3dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_baseline_color_lens_24"
                android:id="@+id/btColor"
                android:layout_width="40dp"
                android:layout_height="40dp" />
            <ImageView
                android:layout_marginHorizontal="3dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_baseline_share_24"
                android:id="@+id/btShare"
                android:layout_width="40dp"
                android:layout_height="40dp" />
            <ImageView
                android:layout_marginHorizontal="3dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_baseline_save_alt_24"
                android:id="@+id/btSave"
                android:layout_width="40dp"
                android:layout_height="40dp" />
            <ImageView
                android:layout_marginHorizontal="3dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_baseline_format_color_text_24"
                android:id="@+id/btTxtColor"
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>