<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <LinearLayout
        android:id="@+id/prayer_item_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/prayer_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_namaz"
            app:tint="?attr/textColorSecondary"
            android:contentDescription="Prayer Icon" />

        <TextView
            android:id="@+id/prayer_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:textColor="?attr/textColorPrimary"
            android:textSize="18sp"
            android:fontFamily="@font/kalpurush"
            tools:text="ফজর" />

        <TextView
            android:id="@+id/prayer_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:textColor="?attr/textColorPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="4:30 AM" />

        <ImageView
            android:id="@+id/alarm_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Alarm Toggle"
            android:focusable="true"
            android:src="@drawable/ic_alarm_on"
            app:tint="?attr/colorPrimary" />

    </LinearLayout>
</layout>
