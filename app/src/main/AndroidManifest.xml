            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.BitActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.FavActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.TafheemActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.NoteActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KitabTafheemNo">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Activity.DarsActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.SubjectActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.VerseActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo"
            android:windowSoftInputMode="stateHidden" />
        <activity
            android:name=".Activity.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
            android:name=".Activity.MapsActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo" />
        <activity
