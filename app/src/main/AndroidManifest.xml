                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.SingleActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.StarkActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.SentenceActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.OvidhanActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.TajwidActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.KitabTafheemNo">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".Activity.AudioActivity"
            android:exported="false">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
